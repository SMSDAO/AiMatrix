{
  "entities": {
    "Feedback": {
      "title": "Feedback",
      "description": "User feedback",
      "type": "object",
      "properties": {
        "metadata": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "object" }
      }
    }
  },
  "firestore": {
    "/feedback/{feedbackId}": {
      "schema": { "$ref": "#/entities/Feedback" },
      "description": "Store all feedback"
    }
  }
}
